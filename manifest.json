{
  "manifest_version": 3,
  "name": "Market Suggestions",
  "version": "1.0.0",
  "description": "Reads webpage content and suggests relevant markets on Kalshi or Polymarket",
  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "https://demo-api.kalshi.co/*",
    "https://kalshi.com/*",
    "https://polymarket.com/*",
    "https://api.openai.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Market Suggestions"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["contentScript.js"],
      "run_at": "document_end"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": ["lib/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
